# Data source: auto (live when a fixture is on, replay otherwise) | live | replay
DATA_MODE=auto

# TxLINE (devnet by default; mainnet: https://txline.txodds.com)
TXLINE_BASE_URL=https://txline-dev.txodds.com
TXLINE_API_TOKEN=            # activated via the TxLINE quickstart flow
# TXLINE_FIXTURE_ID=         # pin a specific fixture (optional)

# Replay
# REPLAY_FILE=data/replays/france-spain.json
REPLAY_SPEED=2

# Solana receipt anchoring (devnet). Either a path or an inline JSON secret key.
ANCHOR_KEYPAIR=.keys/anchor.json
# ANCHOR_SECRET=[1,2,3,...]

# Demo
DEMO_BOTS=8
ADMIN_KEY=change-me
