    "capture": "node scripts/capture.js",
    "test": "node --test test/engine.test.js"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "playwright": "^1.45.0"
  }
}
