{
  "name": "calledit",
  "version": "1.0.0",
  "description": "CalledIt — the World Cup second screen where bragging rights are provable. Powered by TxLINE live data on Solana.",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "server/index.js",
  "scripts": {
